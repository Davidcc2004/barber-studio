# Variables de entorno del servidor — Barber Studio
# Copia este archivo como .env y completa los valores reales
# ⚠️ NUNCA subas el archivo .env a GitHub

# ---- Servidor ----
PUERTO=3000
NODE_ENV=desarrollo

# ---- Supabase (credenciales privadas — solo backend) ----
# Obtenlas desde: https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ---- CORS ----
# URL del frontend en desarrollo
ORIGEN_FRONTEND=http://localhost:5173
